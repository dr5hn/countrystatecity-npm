{
  "name": "countrystatecity-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "fetch-database": "node scripts/fetch-database.cjs",
    "generate-data": "node scripts/generate-all.cjs",
    "update-data": "pnpm fetch-database && pnpm generate-data && pnpm build",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "turbo": "^2.9.14",
    "typescript": "^5.5.4",
    "tsup": "^8.2.4",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0"
}
